# ─── LLM Provider ─────────────────────────────────────────────────────────────
# Choose ONE: openai | anthropic | google | ollama
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=2048

# OpenAI (if LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-...

# Anthropic Claude (if LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-...
# LLM_MODEL=claude-3-5-haiku-20241022

# Google Gemini (if LLM_PROVIDER=google)
GOOGLE_API_KEY=AIza...
# LLM_MODEL=gemini-1.5-flash

# Ollama local (if LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
# LLM_MODEL=llama3.2

# ─── Embeddings ────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=text-embedding-3-small

# ─── Vector Database ──────────────────────────────────────────────────────────
# Choose ONE: chroma | pinecone | weaviate
VECTOR_DB=chroma
CHROMA_PERSIST_DIR=./data/chroma

# Pinecone (if VECTOR_DB=pinecone)
PINECONE_API_KEY=pcsk_...
PINECONE_INDEX=techlearn-courses
PINECONE_NAMESPACE=lessons

# Weaviate (if VECTOR_DB=weaviate)
WEAVIATE_URL=http://localhost:8090
WEAVIATE_API_KEY=
WEAVIATE_CLASS=TechLearnLesson

# ─── RAG Settings ─────────────────────────────────────────────────────────────
RAG_TOP_K=4
RAG_SCORE_THRESHOLD=0.6
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/techlearn

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-key-minimum-256-bits-long-change-in-production

# ─── Code Execution ────────────────────────────────────────────────────────────
ENABLE_CODE_EXECUTION=true
DOCKER_AVAILABLE=true
CODE_EXECUTION_TIMEOUT=10

# ─── App ──────────────────────────────────────────────────────────────────────
DEBUG=false
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:8080"]
